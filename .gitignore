__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
.eggs/
*.whl
.venv/
venv/
env/
.python-version
*.pyo
pip-log.txt

# --- Node.js / Next.js ---
node_modules/
.next/
out/
.vercel

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

