# =============================================================================
# Environment Variables — Vietnamese Stock Clustering Dashboard
# Copy this file to .env and fill in the values. Never commit .env.
# =============================================================================

# --- Supabase Postgres ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# --- FastAPI Backend ---
API_HOST=0.0.0.0
API_PORT=8000
API_ENV=development

# --- AWS (optional, for S3 artifact storage) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
S3_BUCKET_NAME=

# --- VNStock Data Source ---
VNSTOCK_API_KEY=

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_URL=
